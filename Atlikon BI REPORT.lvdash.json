    {
      "name": "0c44ac5d",
      "displayName": "vw_fact_orders_enriched",
      "queryLines": [
        "SELECT * FROM fmcg.gold.vw_fact_orders_enriched"
      ],
      "catalog": "fmcg",
      "schema": "gold"
    },
    {
      "name": "f93683fc",
      "displayName": "Top 10 Products by Revenue",
      "queryLines": [
        "SELECT\n",
        "  product,\n",
        "  SUM(total_amount_inr) as total_revenue\n",
        "FROM\n",
        "  fmcg.gold.vw_fact_orders_enriched\n",
        "GROUP BY\n",
        "  product\n",
        "ORDER BY\n",
        "  total_revenue DESC\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "a550a79c",
      "displayName": "Top Variants by Revenue",
      "queryLines": [
        "SELECT\n",
        "  variant,\n",
        "  SUM(total_amount_inr) as total_revenue\n",
        "FROM\n",
        "  fmcg.gold.vw_fact_orders_enriched\n",
        "GROUP BY\n",
        "  variant\n",
        "ORDER BY\n",
        "  total_revenue DESC\n",
        "LIMIT 10"
      ]
    }
  ],
